# -------------------------------------------------------------------
# 1. Quarto & Rendering-Artefakte
# -------------------------------------------------------------------
# Das interne Verzeichnis von Quarto (Zustand, Preview-Server)
/.quarto/

# Das Standard-Ausgabeverzeichnis der generierten Website
/_site/

# Handout-Render (Profil „handout“ → HTML + PDF)
/_handout/

# Ordner für berechnete Zwischenergebnisse und Caching
*_files/
*_cache/

# -------------------------------------------------------------------
# 2. LaTeX / PDF-Nebenprodukte (falls lokal neben .qmd erzeugt)
# -------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
# Temporäre Pandoc/Quarto-TeX-Dateien neben den Quellen
vorlesungen/*.tex
vorlesungen/*.pdf

# -------------------------------------------------------------------
# 3. Editoren (Cursor / VS Code)
# -------------------------------------------------------------------
# Lokale Workspace-Einstellungen
.vscode/

# ACHTUNG: Die Datei .cursorrules wird hier ABSICHTLICH NICHT
# aufgeführt, da sie zwingend mit ins Repository soll, damit das
# KI-Wissen für zukünftige Semester erhalten bleibt.

# -------------------------------------------------------------------
# 4. Betriebssystem-Dateien
# -------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# -------------------------------------------------------------------
# 5. Lokale Arbeitsartefakte (nicht Teil des Templates)
# -------------------------------------------------------------------
.cursor/slide-review/
assets/images/

# -------------------------------------------------------------------
# 6. Lokale Kompilate & Binärdateien
# -------------------------------------------------------------------
# Falls Sie Quellcode lokal kompilieren,
# sollen die ausführbaren Dateien nicht ins Git-Repo.
*.o
*.out
*.exe
*.bin
*.hex
**/*.quarto_ipynb
